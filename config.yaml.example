excel_path: ./SCHDetailingReport_all_plants_MASTER.xlsm
multi_user:
  enabled: false
  fallback_mode: block
  machine: ''
  username: ''
sheet_name: Current List
sqlite_path: ./schedule.db
ssrs_lookahead_days: 365
ssrs_lookback_days: 30
ssrs_url: http://your-report-server/ReportServer?%2fCustom%2fProduction+Control%2fSCHDetailingReport
status_labels:
  gray: Unassigned (0%)
  green: Released (100%)
  orange: Checked & Returned (95%)
  purple: Ready for Checking (90%)
  red: Overdue
  yellow: In Progress (1-89%)
ui:
  auto_refresh_minutes: 0
  colorblind_mode: none
  high_contrast: false
  last_view: list
  list_column_widths:
    alert_level: 207
    description_tags: 362
    notes: 410
    percent_complete: 93
  list_sort_ascending: true
  list_sort_column: detailing_due_date
  list_visible_columns:
  - com_number
  - detailing_due_date
  - job_name
  - detailer
  - status_color
  - percent_complete
  onboarding_completed: false
  splitter_sizes:
  - 653
  - 523
  theme: dark
unedited_reports_dir: ./Unedited Reports
